---
import Layout from '../layouts/Layout.astro'
---

<Layout title="榜单排名">
  <section class="pt-20 pb-20 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-center mb-12">权威大学排名</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <!-- QS排名 -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">QS 世界大学排名</h3>
          <p class="text-gray-600 text-sm mb-6">全球最受认可的排名系统之一，以学术声誉著称</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看 2024 排名
          </button>
        </div>

        <!-- THE排名 -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">THE 世界大学排名</h3>
          <p class="text-gray-600 text-sm mb-6">英国泰晤士报高等教育专刊发布的权威排名</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看 2024 排名
          </button>
        </div>

        <!-- ARWU排名 -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">ARWU 世界排名</h3>
          <p class="text-gray-600 text-sm mb-6">上海交通大学发布的全球排名，注重科研</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看 2024 排名
          </button>
        </div>

        <!-- 美国排名 -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">US News 美国排名</h3>
          <p class="text-gray-600 text-sm mb-6">美国权威排名，对美国大学申请最有参考</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看 2024 排名
          </button>
        </div>

        <!-- 常青藤 -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">常青藤大学</h3>
          <p class="text-gray-600 text-sm mb-6">美国八所精英私立大学联盟</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看详情
          </button>
        </div>

        <!-- Russell Group -->
        <div class="apple-card">
          <h3 class="font-bold text-lg mb-4">罗素大学集团</h3>
          <p class="text-gray-600 text-sm mb-6">英国24所顶尖研究型大学联盟</p>
          <button class="w-full px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            查看详情
          </button>
        </div>
      </div>

      <!-- 排名对比表 -->
      <div class="apple-card p-0 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-white/50 border-b border-white/20">
              <th class="px-6 py-4 text-left font-semibold">大学名称</th>
              <th class="px-6 py-4 text-left font-semibold">QS 2024</th>
              <th class="px-6 py-4 text-left font-semibold">THE 2024</th>
              <th class="px-6 py-4 text-left font-semibold">ARWU 2023</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-white/10 hover:bg-white/20 transition">
              <td class="px-6 py-4 font-semibold">Harvard University</td>
              <td class="px-6 py-4">5</td>
              <td class="px-6 py-4">4</td>
              <td class="px-6 py-4">1</td>
            </tr>
            <tr class="border-b border-white/10 hover:bg-white/20 transition">
              <td class="px-6 py-4 font-semibold">Stanford University</td>
              <td class="px-6 py-4">3</td>
              <td class="px-6 py-4">5</td>
              <td class="px-6 py-4">2</td>
            </tr>
            <tr class="border-b border-white/10 hover:bg-white/20 transition">
              <td class="px-6 py-4 font-semibold">MIT</td>
              <td class="px-6 py-4">2</td>
              <td class="px-6 py-4">2</td>
              <td class="px-6 py-4">3</td>
            </tr>
            <tr class="border-b border-white/10 hover:bg-white/20 transition">
              <td class="px-6 py-4 font-semibold">University of Oxford</td>
              <td class="px-6 py-4">3</td>
              <td class="px-6 py-4">1</td>
              <td class="px-6 py-4">5</td>
            </tr>
            <tr class="border-b border-white/10 hover:bg-white/20 transition">
              <td class="px-6 py-4 font-semibold">University of Cambridge</td>
              <td class="px-6 py-4">2</td>
              <td class="px-6 py-4">3</td>
              <td class="px-6 py-4">6</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>

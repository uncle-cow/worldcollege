---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'World College - 全球大学升学指南' } = Astro.props
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} - World College</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  </head>
  <body class="bg-gradient-to-br from-slate-50 via-white to-slate-100 font-sans">
    <nav class="sticky top-0 z-50 backdrop-blur-lg bg-white/70 border-b border-white/20 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href={base} class="flex items-center gap-2 font-bold text-lg text-gray-900">
            <span class="text-2xl">🌍</span>
            <span>World College</span>
          </a>
          <div class="hidden md:flex gap-8">
            <a href={`${base}rankings/`} class="text-gray-700 hover:text-blue-600 transition">榜单排名</a>
            <a href={`${base}universities/`} class="text-gray-700 hover:text-blue-600 transition">大学数据库</a>
            <a href={`${base}guides/`} class="text-gray-700 hover:text-blue-600 transition">申请指南</a>
            <a href={`${base}news/`} class="text-gray-700 hover:text-blue-600 transition">最新资讯</a>
          </div>
          <button class="md:hidden p-2 text-gray-700">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="mt-24 border-t border-white/20 bg-white/50 backdrop-blur-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <div>
            <h3 class="font-bold text-lg mb-4">World College</h3>
            <p class="text-gray-600 text-sm">为全球华人提供大学升学信息和指导</p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">导航</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href={`${base}rankings/`} class="hover:text-blue-600">榜单排名</a></li>
              <li><a href={`${base}universities/`} class="hover:text-blue-600">大学数据库</a></li>
              <li><a href={`${base}guides/`} class="hover:text-blue-600">申请指南</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">关于</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href="#" class="hover:text-blue-600">联系我们</a></li>
              <li><a href="#" class="hover:text-blue-600">反馈</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">社交</h4>
            <ul class="space-y-2 text-sm text-gray-600">
              <li><a href="#" class="hover:text-blue-600">GitHub</a></li>
              <li><a href="#" class="hover:text-blue-600">Twitter</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/20 pt-8 text-center text-sm text-gray-600">
          <p>&copy; 2024 World College. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
